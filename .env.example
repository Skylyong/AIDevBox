# ── 路径配置 ──

# 宿主机项目目录（挂载为容器 /workspace）
PROJECT_DIR=~/projects

# Host SSH public key file（单个 .pub 文件，挂载为容器 authorized_keys）
# 使用绝对路径 — Docker 不展开 ~
# 推荐 ed25519 或 RSA；DSA（id_dsa.pub）被新版 sshd 默认拒绝
# Example: /Users/you/.ssh/id_ed25519.pub
SSH_AUTHORIZED_KEYS=/full/path/to/.ssh/id_ed25519.pub

# Host ssh-agent socket（用于容器内 Git/SSH 使用宿主机私钥签名，不复制私钥）
# macOS Docker Desktop: 默认使用 /run/host-services/ssh-auth.sock，可不填写
# Colima: 先启用 forwardAgent 并重启，然后填入 Colima VM 内的 SSH_AUTH_SOCK:
#   colima stop
#   sed -i.bak 's/forwardAgent: false/forwardAgent: true/' ~/.colima/default/colima.yaml
#   colima start
#   echo "SSH_AGENT_SOCKET=$(colima ssh -- printenv SSH_AUTH_SOCK)" >> .env
# Linux Docker engine: 取消注释并填入宿主机当前 SSH_AUTH_SOCK，例如运行:
#   echo "SSH_AGENT_SOCKET=$SSH_AUTH_SOCK" >> .env
# SSH_AGENT_SOCKET=/run/user/1000/keyring/ssh

# ── 可选代理 ──
# 只有在宿主机确实开了代理时才填写，留空则容器直连
# HTTP_PROXY=http://host.docker.internal:7890
# HTTPS_PROXY=http://host.docker.internal:7890
# ALL_PROXY=socks5://host.docker.internal:7890
# NO_PROXY=localhost,127.0.0.1,host.docker.internal
