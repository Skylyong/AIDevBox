# Bailian Coding Plan API Key (shared by Claude Code / Codex / OpenCode)
# Get your key at: https://bailian.console.aliyun.com/cn-beijing/?tab=model#/efm/coding_plan
BAILIAN_API_KEY=sk-your-key-here

# Host proxy port (Clash default: 7890, V2Ray default: 10808)
PROXY_PORT=7890

# Host SSH authorized_keys path (for SSH into container)
SSH_AUTHORIZED_KEYS=/home/ubuntu/.ssh/authorized_keys
