# Bailian Coding Plan API Key (used by Claude Code / OpenCode)
# Get your key at: https://bailian.console.aliyun.com/cn-beijing/?tab=model#/efm/coding_plan
BAILIAN_API_KEY=sk-your-key-here
# OpenAI-compatible API Key (used by Codex)
OPENAI_API_KEY=sk-your-openai-key-here
# Optional host proxy. Leave empty to let the container connect directly.
# Examples:
# HTTP_PROXY=http://host.docker.internal:7890
# HTTPS_PROXY=http://host.docker.internal:7890
# ALL_PROXY=socks5://host.docker.internal:7890
# NO_PROXY=localhost,127.0.0.1,host.docker.internal

# Host SSH public key file (single .pub file mounted as container authorized_keys)
# Use an ABSOLUTE path — Docker does not expand ~ in volume sources.
# Use ed25519 or RSA; DSA (id_dsa.pub) is rejected by modern sshd by default.
# Example (replace with your username): /Users/you/.ssh/id_ed25519.pub
SSH_AUTHORIZED_KEYS=/full/path/to/.ssh/id_ed25519.pub
